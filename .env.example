# =============================================================================
# Laravel ERP Prototype — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#
# For LOCAL development: use the defaults below (MySQL/SQLite)
# For PRODUCTION (Render): set env vars in Render Dashboard, not in .env file
# =============================================================================

# ── Laravel Core ──
APP_NAME=ERP-Prototype
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──
# Local development: MySQL (Laragon) or SQLite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp-prototype
DB_USERNAME=root
DB_PASSWORD=

# ── Session ──
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

# ── Services ──
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ── Mail ──
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ──
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# PRODUCTION SETTINGS (Render Dashboard Environment Variables)
# =============================================================================
# Set these in Render Dashboard → Environment → Environment Variables:
#
# APP_NAME=ERP-Prototype
# APP_ENV=production
# APP_DEBUG=false
# APP_KEY=base64:... (auto-generated or copy from local)
# APP_URL=https://projectkp.onrender.com
# ASSET_URL=https://projectkp.onrender.com
# FORCE_HTTPS=true
#
# DB_CONNECTION=pgsql
# DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
# DB_PORT=6543
# DB_DATABASE=postgres
# DB_USERNAME=postgres.xxxxxxxxxx
# DB_PASSWORD=your-supabase-password
# DB_SSLMODE=require
#
# SESSION_DRIVER=file
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
#
# CACHE_STORE=file
# QUEUE_CONNECTION=sync
#
# LOG_CHANNEL=stderr
# LOG_LEVEL=error
#
# ERP_CLEAN_OPERATIONAL_ON_BOOT=true
#   (opsional, sekali saja) hapus activities/reports dummy saat container start
# =============================================================================
